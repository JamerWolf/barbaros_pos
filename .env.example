# PostgreSQL connection string used by Prisma and the API.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://barbaros:barbaros@localhost:5432/barbaros_pos

# API server port.
PORT=3000

# WebSocket / realtime configuration (placeholder for future Socket.io setup).
# SOCKET_PATH=/socket.io

# Admin PIN for re-opening closed accounts and accessing admin screens.
# Must be a numeric string of at least 4 digits.
# ADMIN_PIN=1234
