# =====================================================
# Bárbaro's POS — environment configuration
# =====================================================
#
# Two committed env files per branch live in apps/api/:
#   - apps/api/.env.develop     → used on the develop branch (port 3000, db port 5432)
#   - apps/api/.env.production  → used on the master branch  (port 3001, db port 5433)
#
# This .env file is OPTIONAL. If present, it is loaded LAST and its values
# take lower priority than the per-env file. Use it for local overrides only.
#
# Do NOT put secrets in the per-env files — they are committed to git.
# For production, inject secrets via the container orchestrator.
#

# Which environment we are running as. Must be: develop | production.
# Must match the .env.<env> file you are using.
APP_ENV=develop

# PostgreSQL connection string. Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# The committed .env.develop / .env.production files already set this correctly.
# DATABASE_URL=postgresql://barbaros:barbaros@localhost:5432/barbaros_pos_dev

# API server port.
# PORT=3000

# Admin PIN for re-opening closed accounts and accessing admin screens.
# Must be a numeric string of at least 4 digits.
# ADMIN_PIN=1234
